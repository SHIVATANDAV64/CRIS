# CRIS Configuration — Amazon Bedrock
# ─────────────────────────────────────────────────────────
#
# 1. Go to https://console.aws.amazon.com/bedrock/
# 2. Enable "MiniMax M2.5" model access in your chosen region
# 3. Generate a long-term API key from the Bedrock console
# 4. Paste it below
#
# Supported regions: us-east-1, us-west-2, eu-central-1, us-east-2

BEDROCK_API_KEY=your_bedrock_api_key_here
BEDROCK_REGION=us-east-1

# ── Optional: Local Model ─────────────────────────────────
# Set to "true" to use a local GGUF model instead of Bedrock
# USE_LOCAL_MODEL=false
